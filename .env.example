# ============================================================
# Autonomous Market AI v1.0.0 — Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# ── AI Provider (OpenAI-compatible) ──────────────────────────
AI_BASE_URL=https://ai.semutssh.com
AI_API_KEY=sk-your-api-key-here

# ── Dashboard ────────────────────────────────────────────────
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_AUTH_TOKEN=             # Bearer token; empty = no auth

# ── Startup Readiness ────────────────────────────────────────
# STARTUP_READINESS_TIMEOUT_MS=10000
# STARTUP_READINESS_MODE=usable          # usable | live
# STARTUP_READINESS_FAILURE_POLICY=warn  # warn | fail
# STARTUP_READINESS_CRYPTO=              # LIVE | DEGRADED | SIMULATION | (empty = no requirement)
# STARTUP_READINESS_FOREX=
# STARTUP_READINESS_COMMODITY=
